# Base URL for the CloudFront API. Required for Explore and Benchmark to work.
# This is the public CloudFront domain — the x-origin-verify secret is injected
# server-side by CloudFront; do NOT add any secret here or in .env.local.
NEXT_PUBLIC_API_BASE_URL=https://your-cloudfront-distribution.cloudfront.net

# Public URL of this site (used for OG tags and sitemap canonical URLs).
# Change to your custom domain once DNS is pointed.
NEXT_PUBLIC_SITE_URL=https://raxorr.github.io/ragornot

# Build-time base path. Set to /ragornot for GitHub Pages project repo.
# Leave empty for a custom domain hosted at the root.
# NEXT_BASE_PATH=/ragornot
